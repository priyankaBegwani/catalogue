# -----------------------------------------------------------------------------
# Backend Type Configuration (Used by: frontend)
# Choose: 'node' (Express.js backend) or 'workers' (Cloudflare Workers)
# -----------------------------------------------------------------------------
VITE_BACKEND_TYPE=workers

# -----------------------------------------------------------------------------
# Backend URLs (Used by: frontend, backend)
# -----------------------------------------------------------------------------
# Node.js Express Backend
PORT=3001
VITE_BACKEND_URL=http://localhost:3001

# Cloudflare Workers Backend
VITE_WORKERS_URL=http://localhost:8787

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage Configuration (Used by: backend, workers)
# All images are stored in Cloudflare R2
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=ic-designs
R2_PUBLIC_URL=https://cdn.indiecraft.in

# Optional: Custom R2 endpoint (defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com)
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# Security (Used by: backend)
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_key_here

# -----------------------------------------------------------------------------
# Tawk.to Chat Configuration (Used by: frontend)
# Get these values from your Tawk.to dashboard (https://dashboard.tawk.to)
# -----------------------------------------------------------------------------
VITE_TAWKTO_PROPERTY_ID=your_property_id_here
VITE_TAWKTO_WIDGET_ID=your_widget_id_here

