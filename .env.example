# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Backend Configuration
PORT=3001
VITE_BACKEND_URL=http://localhost:3001

# Image Storage Configuration
# Options: 'cdn', 'supabase', or 'local'
# - 'cdn': Use Wasabi/Cloudflare CDN (production, requires CDN setup)
# - 'supabase': Use Supabase Storage (fallback, requires bucket setup)
# - 'local': Use local filesystem (development/testing, no external setup needed)
STORAGE_TYPE=local

